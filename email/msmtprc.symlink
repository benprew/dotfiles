defaults
auth           on
tls            on
tls_trust_file /etc/pki/tls/certs/ca-bundle.crt
logfile        ~/.msmtp.log

account        gmail
host           smtp.gmail.com
port           587
from           ben.prew@gmail.com
user           ben.prew@gmail.com
passwordeval   "gpg --quiet --decrypt ~/.mbsync-password.gpg"

account default : gmail
